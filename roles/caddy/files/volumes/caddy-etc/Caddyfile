# Home Server Dashboard
# Services are accessed directly on their own ports.
# Caddy serves the dashboard as the landing page.

:80 {
	root * /srv/dashboard
	# The dashboard is regenerated every 15 min (plus on-demand);
	# tell browsers never to serve a cached copy so a refresh always
	# shows the latest container/backup state.
	header Cache-Control "no-store, max-age=0"
	file_server
}

# Home Server — Caddy configuration
# Generated by Ansible from roles/caddy/templates/volumes/caddy-etc/Caddyfile.j2

{% if caddy_domain %}
# ==================================================================
# Reverse proxy mode — subdomain-based routing with auto HTTPS
# ==================================================================

# Dashboard (root domain)
{{ caddy_domain }} {
	tls internal
	root * /srv/dashboard
	header Cache-Control "no-store, max-age=0"
	file_server
}

# Service reverse proxies
{% for svc in caddy_reverse_proxy_services %}
{{ svc.subdomain }}.{{ caddy_domain }} {
	tls internal
	reverse_proxy {{ svc.proto | default('http') }}://host.containers.internal:{{ svc.port }} {
{% if (svc.proto | default('http')) == 'https' %}
		transport http {
			tls_insecure_skip_verify
		}
{% endif %}
	}
}

{% endfor %}
{% else %}
# ==================================================================
# Simple mode — dashboard only on port 80 (no reverse proxy)
# ==================================================================

:80 {
	root * /srv/dashboard
	header Cache-Control "no-store, max-age=0"
	file_server
}
{% endif %}

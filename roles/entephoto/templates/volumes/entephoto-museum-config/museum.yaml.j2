db:
    host: localhost
    port: 5432
    name: ente_db
    user: pguser
    password: {{ entephoto_db_password }}

s3:
    are_local_buckets: {{ entephoto_s3_local_buckets | to_json }}
    use_path_style_urls: true
    b2-eu-cen:
        key: enteadmin
        secret: {{ entephoto_minio_password }}
        endpoint: {{ entephoto_s3_endpoint }}
        region: eu-central-2
        bucket: b2-eu-cen
    wasabi-eu-central-2-v3:
        key: enteadmin
        secret: {{ entephoto_minio_password }}
        endpoint: {{ entephoto_s3_endpoint }}
        region: eu-central-2
        bucket: wasabi-eu-central-2-v3
        compliance: false
    scw-eu-fr-v3:
        key: enteadmin
        secret: {{ entephoto_minio_password }}
        endpoint: {{ entephoto_s3_endpoint }}
        region: eu-central-2
        bucket: scw-eu-fr-v3

key:
    encryption: {{ entephoto_encryption_key }}
    hash: {{ entephoto_hash_key }}

jwt:
    secret: {{ entephoto_jwt_secret }}

apps:
    public-albums: {{ entephoto_albums_url }}
    cast: http://{{ ansible_facts['default_ipv4']['address'] }}:3004
    accounts: http://{{ ansible_facts['default_ipv4']['address'] }}:3001

internal:
    admins:
{% for admin_id in entephoto_admin_user_ids | default([]) %}
        - {{ admin_id }}
{% endfor %}

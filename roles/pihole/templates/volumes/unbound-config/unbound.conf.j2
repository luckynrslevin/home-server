# Unbound recursive DNS resolver configuration for Pi-hole.
#
# This config is optimised for use as Pi-hole's upstream resolver:
# - Listens on 0.0.0.0:{{ pihole_unbound_port }} (reachable from Pi-hole on localhost)
# - DNSSEC validation enabled
# - Aggressive use of DNSSEC-validated cache
# - Prefetching for popular domains
# - Privacy-oriented: no identity or version queries answered
#
# Based on: https://docs.pi-hole.net/guides/dns/unbound/

server:
    # Listen on all interfaces, port {{ pihole_unbound_port }}
    interface: 0.0.0.0@{{ pihole_unbound_port }}
    interface: ::0@{{ pihole_unbound_port }}

    # Access control — allow localhost and LAN
    access-control: 127.0.0.0/8 allow
    access-control: 10.0.0.0/8 allow
    access-control: 172.16.0.0/12 allow
    access-control: 192.168.0.0/16 allow
    access-control: ::1/128 allow
    access-control: fe80::/10 allow

    # Performance
    num-threads: 2
    msg-cache-size: 64m
    rrset-cache-size: 128m
    key-cache-size: 32m
    neg-cache-size: 16m

    # Prefetch almost-expired records for popular domains
    prefetch: yes
    prefetch-key: yes

    # Serve stale data while fetching fresh responses
    serve-expired: yes
    serve-expired-ttl: 86400

    # DNSSEC validation
    auto-trust-anchor-file: /opt/unbound/etc/unbound/root.key

    # Aggressive NSEC — use cached DNSSEC denial-of-existence data
    aggressive-nsec: yes

    # Privacy — don't reveal version or identity
    hide-identity: yes
    hide-version: yes

    # Harden against various attacks
    harden-algo-downgrade: yes
    harden-below-nxdomain: yes
    harden-dnssec-stripped: yes
    harden-glue: yes
    harden-large-queries: yes
    harden-referral-path: yes
    harden-short-bufsize: yes

    # Minimal responses (smaller packets, faster)
    minimal-responses: yes

    # Use 0x20-encoded random bits in the query to foil spoofing
    use-caps-for-id: yes

    # Logging (minimal — set verbosity to 1 or 2 for debugging)
    verbosity: 0
    logfile: ""
    log-queries: no
    log-replies: no

    # Don't use systemd (container manages the process)
    do-daemonize: no
